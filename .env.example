# Polygon.io
POLYGON_API_KEY=your_polygon_api_key
POLYGON_WS_URL=wss://socket.polygon.io/stocks

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRADES=stock.trades
KAFKA_TOPIC_QUOTES=stock.quotes
KAFKA_TOPIC_ANOMALIES=stock.anomalies
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Spark
SPARK_MASTER=spark://spark-master:7077
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints

# BigQuery
GCP_PROJECT_ID=your-gcp-project
GCP_DATASET=stock_analytics
GCP_CREDENTIALS_PATH=credentials/gcp-key.json

# Snowflake (alternative)
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=STOCK_ANALYTICS
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_ZSCORE_THRESHOLD=3.0

# Symbols to track
STOCK_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA,NVDA,META,JPM,V,JNJ
